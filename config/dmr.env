# ============================================================================
#  DMR  -  הגדרות DSD-FME (ברירת מחדל)
# ----------------------------------------------------------------------------
#  פורמט EnvironmentFile של systemd (KEY=VALUE, מנותח בבטחה - *לא* shell).
#  ⚠️ נכתב מחדש ע"י dmr-web בכל מעבר למצב DMR (לפי המערכת שנבחרה בממשק).
#     ערוך כאן רק כדי לשנות את ברירת המחדל לפני הפעלה ראשונה.
#
#  DSD_CONTROL_FREQ - תדר ערוץ הבקרה (CC) של Cap+ ב-*Hz* (ה-state/UI ב-MHz,
#                     ההמרה נעשית ב-dmr-web). ⚠️ החלף בתדר הרשת שלך.
#  DSD_COLOR_CODE   - color code של הרשת (0–15).
#  DSD_CHANNELMAP   - נתיב ל-channelmap.csv (LCN,FREQ_HZ) — נכתב ע"י dmr-web.
#  DSD_UDP          - יעד פיד ה-JSON (dsd_pty → dmr-web). אל תשנה ללא צורך.
#  DSD_WAV_DIR      - תיקיית per-call WAV.
#  DSD_RTLTCP       - כתובת גשר rsp_tcp (SDRplay→rtl_tcp) ש-DSD-FME מתחבר אליו.
#  DSD_TRUNK        - 1 => מעקב טראנקינג (Cap+).
# ============================================================================
DSD_CONTROL_FREQ=461037500
DSD_COLOR_CODE=1
DSD_CHANNELMAP=/etc/dmr/channelmap.csv
DSD_UDP=127.0.0.1:5555
DSD_WAV_DIR=/var/lib/dmr/recordings
DSD_RTLTCP=127.0.0.1:1234
DSD_TRUNK=1
