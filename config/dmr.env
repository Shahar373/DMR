# ============================================================================
#  DMR - DSD-FME runtime settings (defaults)
# ----------------------------------------------------------------------------
# systemd EnvironmentFile format. dmr-web rewrites the live copy in
# /etc/dmr/dmr.env whenever the selected DMR system changes.
#
# Data path:
#   RSP1B -> rsp_tcp (u8 IQ) -> rsp_fm.py (48 kHz NFM PCM + rigctl) -> DSD-FME
#
# DSD_CONTROL_FREQ - initial control/rest-channel frequency in Hz.
# DSD_COLOR_CODE   - system color code (0-15), retained as system metadata.
# DSD_CHANNELMAP   - DSD-FME LCN/channel map path.
# DSD_RTLTCP       - rsp_tcp IQ endpoint.
# DSD_AUDIO_TCP    - local 48 kHz PCM endpoint exposed by rsp_fm.py.
# DSD_RIGCTL       - local rigctl endpoint used by DSD-FME for trunking retunes.
# DSD_IQ_RATE      - IQ rate requested from rsp_tcp; must be divisible by 48000.
# DSD_AUDIO_GAIN   - FM discriminator output multiplier.
# DSD_UDP          - parsed JSON event destination.
# DSD_WAV_DIR      - DSD-FME per-call WAV directory.
# DSD_TRUNK        - 1 enables trunking.
# ============================================================================
DSD_CONTROL_FREQ=461037500
DSD_COLOR_CODE=1
DSD_CHANNELMAP=/etc/dmr/channelmap.csv
DSD_RTLTCP=127.0.0.1:1234
DSD_AUDIO_TCP=127.0.0.1:7355
DSD_RIGCTL=127.0.0.1:4532
DSD_IQ_RATE=240000
DSD_AUDIO_GAIN=4.0
DSD_UDP=127.0.0.1:5555
DSD_WAV_DIR=/var/lib/dmr/recordings
DSD_TRUNK=1
